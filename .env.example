# ============================================
# SoundReel — Environment Variables (self-hosted)
# ============================================
# Copy to .env and fill. chmod 600 .env.
# ============================================

# --- Postgres ---
DB_PASSWORD=change-me-please

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://soundreel.casamon.dev/spotify/callback

# --- TMDb ---
TMDB_API_KEY=

# --- Ollama (via gpu-router per load balancing archi-PC + geekom) ---
OLLAMA_URL=http://gpu-router:9000
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=moondream:latest

# --- Instaloader ---
# If you want authenticated Instagram fetches, set a username and run:
#   docker exec -it soundreel-instaloader instaloader -l <username>
# once to seed the session cookie (stored in the volume).
INSTALOADER_USERNAME=

# --- Local media pipeline ---
# Whisper ASR + OCR sidecar URLs (internal docker network)
WHISPER_URL=http://soundreel-whisper:9000
OCR_URL=http://soundreel-ocr:5001
# Model size: tiny|base|small|medium|large-v3
WHISPER_MODEL=small
# Shared media volume mount path (inside backend container)
MEDIA_ROOT=/data/media
# Vision key frames per video (1-10)
KEY_FRAMES_COUNT=5

# --- SoundReel read API ---
API_SECRET=

# --- Frontend public URL ---
FRONTEND_URL=https://soundreel.casamon.dev

# --- Spooty (download MP3 da link Spotify via Telegram) ---
SPOOTY_URL=http://spooty:3000
SPOOTY_FRONTEND_URL=https://spooty.casamon.dev

# --- Playwright fallback (JS-rendered pages: Twitter, LinkedIn, etc.) ---
# Chromium installato via apt nel container (bookworm). Disabilitare con false se problemi.
CHROMIUM_PATH=/usr/bin/chromium
PLAYWRIGHT_ENABLED=true
